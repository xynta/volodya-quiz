BOT_TOKEN=put-your-token-from-BotFather-here

# Кому доступна команда /builds (скачивание сборок через бота).
# Username'ы Telegram без @, через запятую. По умолчанию — Ignodeau.
# ADMIN_USERNAMES=Ignodeau

# Где хранить лидерборд (сумма унесённых несгораемых по игрокам).
# По умолчанию — data/leaderboard.json рядом с ботом. Задай абсолютный путь,
# если нужно держать данные на постоянном диске (например, в Docker-volume).
# LEADERBOARD_PATH=/var/lib/volodya-quiz/leaderboard.json
